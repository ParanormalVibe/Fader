<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Fader.ProfilesWindow"
        Title="Profiles"
        Width="420"
        Height="350"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        >
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Name="SelectButton" Content="Change Profile" />
            <Button Name="AddButton" Content="Add" Width="70" />
            <Button Name="RenameButton" Content="Rename" Width="70" />
            <Button Name="RemoveButton" Content="Remove" Width="70" />
        </StackPanel>
        <ListBox Name="ProfileList" />
    </DockPanel>
</Window>
