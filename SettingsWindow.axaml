<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Fader.SettingsWindow"
        Title="Fader Settings"
        Width="320"
        Height="340"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        >
    <StackPanel Margin="16" Spacing="12">
        <TextBlock Text="Gradient Start (transparent)" FontWeight="SemiBold" />
        <Slider Name="StartSlider" Minimum="0" Maximum="1" Value="0"
                TickFrequency="0.01" IsSnapToTickEnabled="True" />

        <TextBlock Text="Gradient End (black)" FontWeight="SemiBold" />
        <Slider Name="EndSlider" Minimum="0" Maximum="1" Value="1"
                TickFrequency="0.01" IsSnapToTickEnabled="True" />

        <CheckBox Name="TopmostCheckBox" Content="Always on top" IsChecked="True" />
        <CheckBox Name="ResizableCheckBox" Content="Resizable" IsChecked="False" />
        <CheckBox Name="DraggableCheckBox" Content="Draggable" IsChecked="False" />
    </StackPanel>
</Window>
